# =============================================================
# PKOS — Environment Variables Template
# Copy file này thành .env và điền vào các giá trị thực tế
# KHÔNG commit file .env lên git
# =============================================================

# ----- Database (PostgreSQL) -----
# Docker Compose local: postgresql://postgres:postgres@localhost:5432/pkos_dev
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pkos_dev"

# ----- Better Auth -----
# Tạo secret: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# ----- Google OAuth -----
# Tạo tại: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ----- App -----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
